{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run test)",
      "Bash(uv run analyze_pdf.py)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.data/**)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp"
  }
}
